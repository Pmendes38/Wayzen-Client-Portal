/**
 * 🚀 WAYZEN CLIENT PORTAL - VERCEL CONFIGURATION
 * 
 * Este arquivo configura o deploy do backend e frontend no Vercel
 * 
 * Deploy Instructions:
 * 1. Instale o Vercel CLI: npm i -g vercel
 * 2. Configure variáveis de ambiente no dashboard
 * 3. Execute: vercel --prod
 */

{
  "version": 2,
  "name": "wayzen-client-portal",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "regions": ["gru1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/server.js"
    }
  ]
}
