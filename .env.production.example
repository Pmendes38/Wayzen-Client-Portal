# =====================================================
# 🚀 VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# =====================================================
# Este arquivo serve como template para configuração de produção
# Copie este arquivo para .env.production e preencha com valores reais
# 
# IMPORTANTE: Nunca commite este arquivo com valores reais!
# =====================================================

# ─────────────────────────────────────────────────────
# 🔐 Supabase Configuration (Produção)
# ─────────────────────────────────────────────────────
# URL do projeto Supabase
SUPABASE_URL=https://stnnvoqvitenovvpqoia.supabase.co

# Service Role Key (BACKEND APENAS - nunca exponha no frontend!)
# Use esta chave apenas no servidor Node.js/Express
# Esta chave bypassa Row Level Security (RLS)
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_aqui

# Anon Key (FRONTEND - chave pública)
# Use esta chave no frontend React
# Esta chave respeita Row Level Security (RLS)
SUPABASE_ANON_KEY=seu_anon_key_aqui

# ─────────────────────────────────────────────────────
# 🔑 JWT Configuration
# ─────────────────────────────────────────────────────
# Secret usado para assinar tokens JWT
# IMPORTANTE: Use um secret forte e único em produção!
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=seu_jwt_secret_super_secreto_aqui_minimo_32_caracteres

# Expiração do token JWT (em segundos)
JWT_EXPIRES_IN=86400

# ─────────────────────────────────────────────────────
# 🌐 Application Configuration
# ─────────────────────────────────────────────────────
# Porta do servidor backend
PORT=3001

# URL base do backend (para CORS)
BACKEND_URL=https://seu-backend.vercel.app

# URL base do frontend (para CORS)
FRONTEND_URL=https://seu-frontend.vercel.app

# Ambiente (production, staging, development)
NODE_ENV=production

# ─────────────────────────────────────────────────────
# 📧 Email Configuration (Opcional - para futuro)
# ─────────────────────────────────────────────────────
# Configurar quando migrar para Supabase Auth
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app
# EMAIL_FROM=noreply@wayzen.com.br

# ─────────────────────────────────────────────────────
# 📊 Monitoring & Analytics (Opcional)
# ─────────────────────────────────────────────────────
# Sentry DSN para error tracking
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Google Analytics ID
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# ─────────────────────────────────────────────────────
# 💾 Database Configuration
# ─────────────────────────────────────────────────────
# URL de conexão do PostgreSQL (opcional - Supabase já fornece)
# Útil para ferramentas como Prisma, TypeORM, etc.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.stnnvoqvitenovvpqoia.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────
# 🔒 Security Headers (Opcional)
# ─────────────────────────────────────────────────────
# CORS_ORIGIN=https://seu-dominio.com.br
# ALLOWED_ORIGINS=https://seu-dominio.com.br,https://www.seu-dominio.com.br

# Rate limiting
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────────────
# ☁️ Cloud Storage (Opcional - para futuro)
# ─────────────────────────────────────────────────────
# AWS S3 ou Supabase Storage para arquivos
# STORAGE_BUCKET=wayzen-documents
# AWS_ACCESS_KEY_ID=seu_access_key
# AWS_SECRET_ACCESS_KEY=seu_secret_key
# AWS_REGION=us-east-1

# =====================================================
# 📝 NOTAS DE SEGURANÇA
# =====================================================
# 
# 1. NUNCA commite arquivos .env com valores reais
# 2. Use diferentes secrets para cada ambiente
# 3. Rotacione secrets regularmente
# 4. Use variáveis de ambiente da plataforma de deploy:
#    - Vercel: https://vercel.com/docs/concepts/projects/environment-variables
#    - Railway: https://docs.railway.app/deploy/variables
#    - Render: https://render.com/docs/environment-variables
# 5. Service Role Key deve ser usado APENAS no backend
# 6. Anon Key pode ser exposta no frontend (ela respeita RLS)
# 
# =====================================================

# =====================================================
# 🚀 DEPLOY CHECKLIST
# =====================================================
# 
# Antes de fazer deploy:
# 
# [ ] Gerar novo JWT_SECRET forte
# [ ] Configurar todas as variáveis de ambiente na plataforma
# [ ] Verificar CORS origins (FRONTEND_URL, BACKEND_URL)
# [ ] Habilitar RLS nas tabelas do Supabase
# [ ] Executar supabase-rls-policies.sql
# [ ] Testar todas as rotas em staging
# [ ] Configurar domínio personalizado
# [ ] Configurar SSL/HTTPS
# [ ] Configurar monitoramento (Sentry, LogRocket, etc.)
# [ ] Backup do banco de dados
# [ ] Documentar processo de rollback
# 
# =====================================================
